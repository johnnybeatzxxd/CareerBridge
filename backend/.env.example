# Gmail SMTP
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_APP_PASSWORD=your-16-character-app-password-without-spaces
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_AUTH=true
SMTP_STARTTLS=true

# Application security
JWT_SECRET=replace-with-a-long-random-secret
OTP_SECRET=replace-with-another-long-random-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
COOKIE_SECURE=false

# Frontend
FRONTEND_ORIGIN=http://localhost:5173

# Embedded H2 database
DB_URL=jdbc:h2:file:./data/jobsite;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;AUTO_SERVER=TRUE
DB_USER=sa
DB_PASSWORD=
